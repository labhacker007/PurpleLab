# Joti Sim Environment Configuration
# Copy this file to .env and fill in the values

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://jotisim:jotisim@localhost:5433/jotisim

# Redis
REDIS_URL=redis://localhost:6380/0

# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default LLM model
DEFAULT_MODEL=claude-sonnet-4-20250514

# Application
APP_NAME=Joti Sim
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:4000"]

# Encryption key for SIEM credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Celery (background tasks)
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# Vector DB (ChromaDB)
CHROMA_PERSIST_DIR=./data/chroma
