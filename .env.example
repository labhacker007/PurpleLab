# ─────────────────────────────────────────────────────────────────────────────
#  PurpleLab — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Generate secret keys with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (asyncpg driver)
# Docker Compose overrides this to use the 'postgres' service hostname automatically.
DATABASE_URL=postgresql+asyncpg://purplelab:purplelab@localhost:5433/purplelab

# Postgres password (used by docker-compose to set POSTGRES_PASSWORD)
POSTGRES_PASSWORD=purplelab

# Host port to expose PostgreSQL on (default 5433 to avoid conflict with local pg)
POSTGRES_PORT=5433


# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection URL (database 0 for app cache/sessions)
# Docker Compose overrides this to use the 'redis' service hostname automatically.
REDIS_URL=redis://localhost:6380/0

# Host port to expose Redis on (default 6380 to avoid conflict with local Redis)
REDIS_PORT=6380

# Celery broker (database 1) and result backend (database 2)
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2


# ── Authentication & Security ─────────────────────────────────────────────────

# JWT signing secret — MUST be changed in production
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-32-char-minimum

# JWT algorithm (HS256 is standard; use RS256 for asymmetric keys)
JWT_ALGORITHM=HS256

# Access token expiry in minutes (default: 60 minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token expiry in days (default: 30 days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Fernet symmetric key for encrypting stored SIEM credentials
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=


# ── First Superadmin (auto-created on startup if both are set) ────────────────

FIRST_SUPERADMIN_EMAIL=
FIRST_SUPERADMIN_PASSWORD=


# ── LLM Providers ─────────────────────────────────────────────────────────────

# Default model used when no per-function override is configured
DEFAULT_MODEL=claude-sonnet-4-20250514

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, o1) — https://platform.openai.com/
OPENAI_API_KEY=

# Google Gemini (native SDK, used for embeddings) — https://aistudio.google.com/
GOOGLE_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Ollama (local inference — OpenAI-compatible endpoint, no extra package needed)
OLLAMA_BASE_URL=http://localhost:11434

# ── Per-function LLM overrides (optional) ─────────────────────────────────────
# Override the provider/model for a specific pipeline function.
# Format: PURPLELAB_LLM_{FUNCTION}_{FIELD}
# Example:
#   PURPLELAB_LLM_LOG_GENERATION_PROVIDER=ollama
#   PURPLELAB_LLM_LOG_GENERATION_MODEL=llama3.2


# ── Joti Integration (optional) ──────────────────────────────────────────────

# Base URL of your Joti instance (leave empty to disable)
JOTI_BASE_URL=

# Joti API key (format: joti_<64 hex chars>)
JOTI_API_KEY=

# Webhook token for Joti -> PurpleLab alert ingestion endpoint
JOTI_WEBHOOK_TOKEN=


# ── Application Settings ──────────────────────────────────────────────────────

APP_NAME=PurpleLab

# Debug mode — enables verbose logging and unrestricted CORS (disable in production)
DEBUG=false

# CORS allowed origins (comma-separated list, ignored when DEBUG=true)
CORS_ORIGINS=["http://localhost:3000","https://purplelab.yourorg.com"]

# ChromaDB persistence directory (mapped to /app/data/chroma inside container)
CHROMA_PERSIST_DIR=./data/chroma


# ── Frontend ──────────────────────────────────────────────────────────────────

# Public API URL embedded into the Next.js build (used by browser clients)
# In Docker Compose the frontend proxies via the 'backend' service internally.
NEXT_PUBLIC_API_URL=http://localhost:8000
